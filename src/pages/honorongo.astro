---
import HonRongoLayout from "../layouts/HonRongoLayout.astro";
---

<HonRongoLayout title="Rongo - Accesibilidad Telefónica">
  <!-- Hero Section -->
  <section
    class="scroll-section pb-20 sm:pb-24 md:pb-32 px-4 gradient-hero relative overflow-hidden flex items-center justify-center"
  >
    <div class="absolute inset-0 opacity-10">
      <svg
        class="w-full h-full"
        viewBox="0 0 1200 600"
        preserveAspectRatio="none"
      >
        <defs>
          <pattern
            id="wave"
            x="0"
            y="0"
            width="120"
            height="120"
            patternUnits="userSpaceOnUse"
          >
            <path
              d="M0,60 Q30,50 60,60 T120,60"
              stroke="#A5B4FC"
              stroke-width="2"
              fill="none"></path>
          </pattern>
        </defs>
        <rect width="1200" height="600" fill="url(#wave)"></rect>
      </svg>
    </div>

    <div class="max-w-7xl mx-auto relative z-10 text-center">
      <h1
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-4 sm:mb-6 leading-tight"
      >
        Escuchar para <span class="block">Conectar</span>
      </h1>
      <p
        class="text-base sm:text-lg md:text-xl lg:text-2xl text-white/90 mb-6 sm:mb-10 max-w-3xl mx-auto leading-relaxed"
      >
        La primera solución bidireccional de accesibilidad telefónica. <strong
          >100% privada, offline y confiable.</strong
        >
      </p>

      <!-- Stats -->
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 mt-12 sm:mt-16 lg:mt-20 max-w-3xl mx-auto px-0"
      >
        <div class="bg-white/10 backdrop-blur rounded-lg p-4 sm:p-6 text-white">
          <div class="text-2xl sm:text-3xl font-bold text-accent mb-2">
            700K+
          </div>
          <div class="text-xs sm:text-sm opacity-90">
            Personas con discapacidad auditiva en Chile
          </div>
        </div>
        <div class="bg-white/10 backdrop-blur rounded-lg p-6 text-white">
          <div class="text-2xl sm:text-3xl font-bold text-accent mb-2">
            1.5B
          </div>
          <div class="text-xs sm:text-sm opacity-90">
            Usuarios potenciales globales
          </div>
        </div>
        <div class="bg-white/10 backdrop-blur rounded-lg p-6 text-white">
          <div class="text-2xl sm:text-3xl font-bold text-accent mb-2">
            &lt;200ms
          </div>
          <div class="text-xs sm:text-sm opacity-90">
            Latencia crítica conseguida
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- NEW SECTION: CONTEXTO REAL (Accordion System) -->
  <!-- ============================================== -->
  <section
    id="contexto"
    class="scroll-section py-16 sm:py-20 md:py-24 px-4 bg-white relative"
  >
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12 sm:mb-16">
        <h2 class="section-title">El Contexto Real: La Brecha Invisible</h2>
        <p class="section-subtitle mx-auto">
          Basado en el <strong class="text-primary"
            >Informe de Brechas de Accesibilidad</strong
          >. No es solo un problema de audición, es un problema de sincronía y
          derechos.
        </p>
      </div>

      <!-- Main Accordion Container -->
      <div class="space-y-6">
        <!-- Accordion 1: Deaf Community -->
        <div
          class="card p-0 overflow-hidden border-l-8 border-l-secondary accordion-wrapper group"
        >
          <button
            class="w-full text-left p-8 flex justify-between items-center hover:bg-gray-50 transition-colors"
          >
            <div class="flex items-center gap-6">
              <div
                class="w-16 h-16 rounded-full bg-secondary/10 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform"
              >
                🧏
              </div>
              <div>
                <h3 class="text-2xl font-bold text-primary">
                  Comunidad Sorda e Hipoacúsica
                </h3>
                <p class="text-gray-500">
                  Más de 500.000 personas. Contexto LSCh vs Español.
                </p>
              </div>
            </div>
            <div
              class="text-4xl text-gray-300 group-hover:text-secondary transition-colors origin-center transform duration-300 accordion-arrow"
            >
              ↓
            </div>
          </button>

          <div
            class="accordion-content hidden bg-gray-50/50 p-8 border-t border-gray-100"
          >
            <div class="grid md:grid-cols-2 gap-8 mb-8">
              <!-- Left: The Problem & State Gap -->
              <div class="space-y-6">
                <div>
                  <h4
                    class="font-bold text-gray-800 mb-2 flex items-center gap-2"
                  >
                    🏛️ Ayuda Estatal Actual
                  </h4>
                  <ul
                    class="text-sm text-gray-600 bg-white p-4 rounded-lg border border-gray-200 shadow-sm space-y-2"
                  >
                    <li>
                      • <strong>GES/AUGE:</strong> Audífonos e implantes cocleares.
                    </li>
                    <li>
                      • <strong>VIAD:</strong> Plataforma de video-interpretación.
                    </li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-bold text-error mb-2 flex items-center gap-2">
                    ⚠️ La Brecha Real (Lo que falta)
                  </h4>
                  <ul class="list-disc pl-5 space-y-2 text-sm text-gray-700">
                    <li>
                      <strong>Inaccesibilidad GSM:</strong> La red telefónica es 100%
                      audio. Los audífonos se acoplan o no sirven para llamar.
                    </li>
                    <li>
                      <strong>Dependencia:</strong> VIAD requiere un 3ro humano (pérdida
                      de privacidad) y depende de horarios/internet.
                    </li>
                    <li>
                      <strong>Urgencia:</strong> No pueden llamar al 133/131 por sí
                      mismos.
                    </li>
                  </ul>
                </div>
              </div>

              <!-- Right: Rongo Solution -->
              <div
                class="bg-white p-6 rounded-xl border border-secondary/20 shadow-sm relative flex flex-col justify-center"
              >
                <div
                  class="absolute -top-3 -right-3 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full shadow-md"
                >
                  SOLUCIÓN RONGO
                </div>
                <h4 class="font-bold text-primary mb-3 text-lg">
                  👂 → 👁️ Puente Sensorial
                </h4>
                <p class="text-sm text-gray-700 mb-4">
                  Rongo transforma el <strong>Audio en Texto Visual</strong> en tiempo
                  real, sin intermediarios.
                </p>
                <div class="space-y-3">
                  <div class="flex items-center gap-3">
                    <span
                      class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center text-xs"
                      >✔</span
                    >
                    <span class="text-sm text-gray-600"
                      ><strong>Privacidad Total:</strong> Edge AI local. Nadie te
                      lee.</span
                    >
                  </div>
                  <div class="flex items-center gap-3">
                    <span
                      class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center text-xs"
                      >✔</span
                    >
                    <span class="text-sm text-gray-600"
                      ><strong>100% Offline:</strong> Funciona en zonas rurales.</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Accordion 2: Speech Disorders & Aphasia -->
        <div
          class="card p-0 overflow-hidden border-l-8 border-l-primary accordion-wrapper group"
        >
          <button
            class="w-full text-left p-8 flex justify-between items-center hover:bg-gray-50 transition-colors"
          >
            <div class="flex items-center gap-6">
              <div
                class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform"
              >
                🗣️
              </div>
              <div>
                <h3 class="text-2xl font-bold text-primary">
                  Trastornos del Habla y Afasias
                </h3>
                <p class="text-gray-500">
                  Mudos, Laringectomizados, Secuelas ACV.
                </p>
              </div>
            </div>
            <div
              class="text-4xl text-gray-300 group-hover:text-primary transition-colors origin-center transform duration-300 accordion-arrow"
            >
              ↓
            </div>
          </button>

          <div
            class="accordion-content hidden bg-gray-50/50 p-8 border-t border-gray-100"
          >
            <div class="grid md:grid-cols-2 gap-8 mb-8">
              <!-- Left: The Problem & State Gap -->
              <div class="space-y-6">
                <div>
                  <h4
                    class="font-bold text-gray-800 mb-2 flex items-center gap-2"
                  >
                    🏛️ Ayuda Estatal Actual
                  </h4>
                  <ul
                    class="text-sm text-gray-600 bg-white p-4 rounded-lg border border-gray-200 shadow-sm space-y-2"
                  >
                    <li>
                      • <strong>Rehabilitación:</strong> Fonoaudiología en sistema
                      público.
                    </li>
                    <li>
                      • <strong>Credencial:</strong> Beneficios y subsidios sociales.
                    </li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-bold text-error mb-2 flex items-center gap-2">
                    ⚠️ La Brecha de Tiempo
                  </h4>
                  <ul class="list-disc pl-5 space-y-2 text-sm text-gray-700">
                    <li>
                      <strong>Latencia Crítica:</strong> Pueden escuchar, pero no
                      responder en &lt;2 seg. <span class="italic"
                        >Resultado: Les cortan la llamada.</span
                      >
                    </li>
                    <li>
                      <strong>Calidad de Voz:</strong> Voces esofágicas suenan metálicas
                      o robóticas por teléfono.
                    </li>
                  </ul>
                </div>
              </div>

              <!-- Right: Rongo Solution -->
              <div
                class="bg-white p-6 rounded-xl border border-primary/20 shadow-sm relative flex flex-col justify-center"
              >
                <div
                  class="absolute -top-3 -right-3 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full shadow-md"
                >
                  SOLUCIÓN RONGO
                </div>
                <h4 class="font-bold text-primary mb-3 text-lg">
                  🖐️ → 🗣️ Puente Sensorial
                </h4>
                <p class="text-sm text-gray-700 mb-4">
                  Rongo transforma tu <strong>Escritura en Voz Natural</strong> instantánea.
                </p>
                <div class="space-y-3">
                  <div class="flex items-center gap-3">
                    <span
                      class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center text-xs"
                      >✔</span
                    >
                    <span class="text-sm text-gray-600"
                      ><strong>TTS Neural:</strong> Voz humana chilena, no robot.</span
                    >
                  </div>
                  <div class="flex items-center gap-3">
                    <span
                      class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center text-xs"
                      >✔</span
                    >
                    <span class="text-sm text-gray-600"
                      ><strong>Velocidad:</strong> Respuestas rápidas de un toque.</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Accordion 3: Neurodivergence & ASD -->
        <div
          class="card p-0 overflow-hidden border-l-8 border-l-accent accordion-wrapper group"
        >
          <button
            class="w-full text-left p-8 flex justify-between items-center hover:bg-gray-50 transition-colors"
          >
            <div class="flex items-center gap-6">
              <div
                class="w-16 h-16 rounded-full bg-accent/20 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform"
              >
                🧠
              </div>
              <div>
                <h3 class="text-2xl font-bold text-primary">
                  Neurodivergencia y TEA
                </h3>
                <p class="text-gray-500">
                  Ley TEA 21.545 - Ansiedad Social y Telefobia.
                </p>
              </div>
            </div>
            <div
              class="text-4xl text-gray-300 group-hover:text-accent transition-colors origin-center transform duration-300 accordion-arrow"
            >
              ↓
            </div>
          </button>

          <div
            class="accordion-content hidden bg-gray-50/50 p-8 border-t border-gray-100"
          >
            <div class="grid md:grid-cols-2 gap-8 mb-8">
              <!-- Left: The Problem & State Gap -->
              <div class="space-y-6">
                <div>
                  <h4
                    class="font-bold text-gray-800 mb-2 flex items-center gap-2"
                  >
                    🏛️ Ayuda Estatal Actual
                  </h4>
                  <ul
                    class="text-sm text-gray-600 bg-white p-4 rounded-lg border border-gray-200 shadow-sm space-y-2"
                  >
                    <li>
                      • <strong>Ley TEA:</strong> Diagnóstico e inclusión escolar/laboral.
                    </li>
                    <li>
                      • <strong>Espacios de Calma:</strong> Adaptaciones físicas en
                      escuelas.
                    </li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-bold text-error mb-2 flex items-center gap-2">
                    ⚠️ Sobrecarga Sensorial
                  </h4>
                  <ul class="list-disc pl-5 space-y-2 text-sm text-gray-700">
                    <li>
                      <strong>Telefobia:</strong> El audio de baja calidad + presión
                      de tiempo = Bloqueo (Shutdown).
                    </li>
                    <li>
                      <strong>Vacío Digital:</strong> La Ley TEA no cubre herramientas
                      tecnológicas para la vida diaria independiente.
                    </li>
                  </ul>
                </div>
              </div>

              <!-- Right: Rongo Solution -->
              <div
                class="bg-white p-6 rounded-xl border border-accent/30 shadow-sm relative flex flex-col justify-center"
              >
                <div
                  class="absolute -top-3 -right-3 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full shadow-md"
                >
                  SOLUCIÓN RONGO
                </div>
                <h4 class="font-bold text-primary mb-3 text-lg">
                  🛡️ Puente Sensorial: El Escudo
                </h4>
                <p class="text-sm text-gray-700 mb-4">
                  Un <strong>Buffer Cognitivo</strong>. Lee a tu ritmo, responde
                  cuando estés listo.
                </p>
                <div class="space-y-3">
                  <div class="flex items-center gap-3">
                    <span
                      class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center text-xs"
                      >✔</span
                    >
                    <span class="text-sm text-gray-600"
                      >Elimina ruido de fondo y ansiedad.</span
                    >
                  </div>
                  <div class="flex items-center gap-3">
                    <span
                      class="w-6 h-6 rounded-full bg-green-100 text-green-600 flex items-center justify-center text-xs"
                      >✔</span
                    >
                    <span class="text-sm text-gray-600"
                      >Permite gestión de tiempos (sin presión).</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Accordion 4: La Gran Brecha -->
        <div
          class="card p-0 overflow-hidden border-l-8 border-l-error accordion-wrapper group"
        >
          <button
            class="w-full text-left p-8 flex justify-between items-center hover:bg-gray-50 transition-colors"
          >
            <div class="flex items-center gap-6">
              <div
                class="w-16 h-16 rounded-full bg-error/10 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform"
              >
                🚧
              </div>
              <div>
                <h3 class="text-2xl font-bold text-primary">
                  La "Gran Brecha": El Canal Telefónico como Muro
                </h3>
                <p class="text-gray-500">
                  3 Brechas Críticas: Tiempo, Formato y Privacidad.
                </p>
              </div>
            </div>
            <div
              class="text-4xl text-gray-300 group-hover:text-error transition-colors origin-center transform duration-300 accordion-arrow"
            >
              ↓
            </div>
          </button>

          <div
            class="accordion-content hidden bg-gray-50/50 p-8 border-t border-gray-100"
          >
            <p class="text-gray-700 mb-6">
              Existe una brecha tecnológica específica que nadie está cubriendo: <strong
                >La Sincronía del Audio</strong
              >.
            </p>
            <div
              class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6"
            >
              <!-- Brecha 1 -->
              <div
                class="bg-white p-4 sm:p-5 md:p-6 rounded-xl border border-error/20 shadow-sm"
              >
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-2xl">⏱️</span>
                  <h4 class="font-bold text-error">Brecha de Tiempo</h4>
                </div>
                <p class="text-sm text-gray-600 mb-3">
                  Las llamadas exigen respuestas inmediatas (&lt; 2 segundos).
                </p>
                <p
                  class="text-xs text-gray-500 italic bg-gray-100 p-3 rounded-lg"
                >
                  <strong>Impacto:</strong> Las personas con tartamudez, afasia o
                  TEA necesitan más tiempo de procesamiento. Al no responder rápido,
                  el interlocutor corta.
                </p>
              </div>
              <!-- Brecha 2 -->
              <div
                class="bg-white p-4 sm:p-5 md:p-6 rounded-xl border border-error/20 shadow-sm"
              >
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-2xl">📻</span>
                  <h4 class="font-bold text-error">Brecha de Formato</h4>
                </div>
                <p class="text-sm text-gray-600 mb-3">
                  La red telefónica solo transmite audio.
                </p>
                <p
                  class="text-xs text-gray-500 italic bg-gray-100 p-3 rounded-lg"
                >
                  <strong>Impacto:</strong> Las personas Sordas quedan fuera del sistema
                  financiero, salud y emergencias que dependen de llamadas telefónicas.
                </p>
              </div>
              <!-- Brecha 3 -->
              <div
                class="bg-white p-4 sm:p-5 md:p-6 rounded-xl border border-error/20 shadow-sm"
              >
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-2xl">🔒</span>
                  <h4 class="font-bold text-error">Brecha de Privacidad</h4>
                </div>
                <p class="text-sm text-gray-600 mb-3">
                  Las soluciones actuales requieren intermediarios humanos.
                </p>
                <p
                  class="text-xs text-gray-500 italic bg-gray-100 p-3 rounded-lg"
                >
                  <strong>Impacto:</strong> Un adulto no es independiente si su madre
                  debe llamar al médico por él. Se pierde la autonomía.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Accordion 5: Argumento de Integración -->
        <div
          class="card p-0 overflow-hidden border-l-8 border-l-success accordion-wrapper group"
        >
          <button
            class="w-full text-left p-8 flex justify-between items-center hover:bg-gray-50 transition-colors"
          >
            <div class="flex items-center gap-6">
              <div
                class="w-16 h-16 rounded-full bg-success/10 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform"
              >
                🌉
              </div>
              <div>
                <h3 class="text-2xl font-bold text-primary">
                  HonoRongo: El Puente Sensorial
                </h3>
                <p class="text-gray-500">
                  Justificación de la solución ante la brecha nacional.
                </p>
              </div>
            </div>
            <div
              class="text-4xl text-gray-300 group-hover:text-success transition-colors origin-center transform duration-300 accordion-arrow"
            >
              ↓
            </div>
          </button>

          <div
            class="accordion-content hidden bg-gray-50/50 p-8 border-t border-gray-100"
          >
            <p class="text-gray-700 mb-6">
              Mientras el Estado Chileno se enfoca en la rehabilitación clínica
              (audífonos, terapias) y la accesibilidad física (rampas, lengua de
              señas en TV), <strong class="text-primary"
                >HonoRongo aborda la accesibilidad digital en
                telecomunicaciones.</strong
              >
            </p>
            <div class="grid md:grid-cols-3 gap-6 mb-8">
              <!-- Para el Sordo -->
              <div
                class="bg-white p-6 rounded-xl border border-secondary/20 shadow-sm text-center"
              >
                <div class="text-4xl mb-3">👂 → 👁️</div>
                <h4 class="font-bold text-primary mb-2">Para el Sordo</h4>
                <p class="text-sm text-gray-600">
                  Transforma el canal auditivo (inaccesible) en <strong
                    >visual</strong
                  > (accesible).
                </p>
              </div>
              <!-- Para el Mudo -->
              <div
                class="bg-white p-6 rounded-xl border border-primary/20 shadow-sm text-center"
              >
                <div class="text-4xl mb-3">🖐️ → 🗣️</div>
                <h4 class="font-bold text-primary mb-2">
                  Para el Mudo/Afásico
                </h4>
                <p class="text-sm text-gray-600">
                  Transforma el input táctil (texto) en <strong
                    >output auditivo</strong
                  > (voz).
                </p>
              </div>
              <!-- Para TEA -->
              <div
                class="bg-white p-6 rounded-xl border border-accent/30 shadow-sm text-center"
              >
                <div class="text-4xl mb-3">🛡️</div>
                <h4 class="font-bold text-primary mb-2">Para Persona TEA</h4>
                <p class="text-sm text-gray-600">
                  Actúa como un <strong>"escudo"</strong> que reduce la carga sensorial
                  y la presión social.
                </p>
              </div>
            </div>
            <div class="bg-primary/5 p-6 rounded-xl border border-primary/20">
              <p class="text-gray-700 italic text-center">
                "Al operar de manera local (offline) y mediante IA, democratiza
                el acceso sin depender de planes de datos costosos ni de la
                disponibilidad de intérpretes humanos, devolviendo el derecho
                fundamental a la <strong>privacidad y autonomía</strong>."
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Visión y Misión -->
  <section class="py-20 px-4 bg-gradient-to-r from-accent/10 to-primary/10">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12">
        <div class="card">
          <h3 class="text-2xl font-bold text-primary mb-4">
            🎯 Nuestra Misión
          </h3>
          <p class="text-text-primary leading-relaxed">
            Romper la barrera del silencio en las comunicaciones telefónicas.
            Queremos que 700 mil personas en Chile —y 1.5 billones en el mundo—
            puedan contestar una llamada, expresarse y sentir que el mundo las
            escucha, sin depender de terceros y sin comprometer su privacidad.
          </p>
        </div>
        <div class="card">
          <h3 class="text-2xl font-bold text-primary mb-4">
            ✨ Nuestra Visión
          </h3>
          <p class="text-text-primary leading-relaxed">
            Un mundo donde la discapacidad auditiva no sea barrera para la
            comunicación. Rongo es el puente que transforma cada teléfono en una
            terminal accesible, descentralizada y centrada en la dignidad de
            quienes la usan.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solución Section -->
  <section
    id="solucion"
    class="scroll-section py-20 px-4 bg-gradient-to-b from-accent/5 to-accent/10"
  >
    <div class="max-w-7xl mx-auto">
