  <script is:inline>
    window.addEventListener("load", function () {
      var accordionTriggers = document.querySelectorAll(
        ".accordion-wrapper button",
      );
      console.log(
        "Accordion script loaded. Found " +
          accordionTriggers.length +
          " triggers.",
      );

      for (var i = 0; i < accordionTriggers.length; i++) {
        accordionTriggers[i].addEventListener("click", function (e) {
          e.preventDefault();
          e.stopPropagation();

          var wrapper = this.closest(".accordion-wrapper");
          var content = wrapper.querySelector(".accordion-content");
          var arrow = wrapper.querySelector(".accordion-arrow");

          // Close all others
          var allWrappers = document.querySelectorAll(".accordion-wrapper");
          for (var j = 0; j < allWrappers.length; j++) {
            if (allWrappers[j] !== wrapper) {
              allWrappers[j]
                .querySelector(".accordion-content")
                .classList.add("hidden");
              var otherArrow = allWrappers[j].querySelector(".accordion-arrow");
              if (otherArrow) otherArrow.classList.remove("rotate-180");
            }
          }

          // Toggle current
          content.classList.toggle("hidden");
          if (arrow) arrow.classList.toggle("rotate-180");
        });
      }
    });
  </script>
