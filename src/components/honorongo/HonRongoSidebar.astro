---
const navigationItems = [
  { name: "Contexto", href: "#contexto", icon: "📊" },
  { name: "Solución", href: "#solucion", icon: "💡" },
  { name: "Ventajas", href: "#diferenciacion", icon: "✨" },
  { name: "Impacto", href: "#impacto", icon: "🎯" },
  { name: "Roadmap", href: "#roadmap", icon: "🛣️" },
  { name: "Inversión", href: "#inversion", icon: "💰" },
];
---

<nav class="flex flex-col h-full bg-white min-w-[200px]">
  <!-- Logo/Title Section -->
  <div class="px-3 py-3 border-b border-slate-100">
    <a href="#" class="block" title="Ir al inicio">
      <img
        src="/images/logorongo.webp"
        alt="HonoRongo"
        class="h-8 w-auto object-contain cursor-pointer hover:opacity-80 transition-opacity"
      />
    </a>
  </div>

  <!-- Navigation Links -->
  <ul class="flex-1 overflow-y-auto px-2 py-2 space-y-1">
    {
      navigationItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="flex items-center gap-2 px-3 py-2 rounded-lg text-slate-700 hover:bg-blue-50 hover:text-blue-600 transition-all duration-200 font-medium text-sm group whitespace-nowrap"
          >
            <span class="text-lg group-hover:scale-110 transition-transform">
              {item.icon}
            </span>
            <span>{item.name}</span>
          </a>
        </li>
      ))
    }
  </ul>

  <!-- Footer CTA -->
  <div class="px-2 py-3 border-t border-slate-100">
    <a
      href="#contacto"
      class="block w-full px-3 py-2 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-lg text-center font-semibold hover:from-blue-700 hover:to-indigo-700 transition-all shadow-lg shadow-blue-500/25 text-sm"
    >
      Contactar
    </a>
  </div>
</nav>

<style>
  /* Smooth scroll behavior for anchor links */
  nav a[href^="#"] {
    cursor: pointer;
  }
</style>
